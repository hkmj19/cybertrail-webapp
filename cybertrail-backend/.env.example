# ── Backup encryption ────────────────────────────────────
# Used to AES-256 encrypt exported backup files
# Change this to a strong password before going live
BACKUP_ENCRYPTION_PASSWORD=CyberTrail@Backup#2026

# ── Server ──────────────────────────────────────────────
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000

# ── Neo4j (graph database) ───────────────────────────────
# Run locally: docker-compose up -d
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=cybertrail123

# ── Redis (caching API responses) ────────────────────────
REDIS_URL=redis://localhost:6379/0
CACHE_TTL_SECONDS=3600        # 1 hour default

# ── Crypto APIs ──────────────────────────────────────────
# Free tier available at etherscan.io
ETHERSCAN_API_KEY=YOUR_ETHERSCAN_API_KEY

# Free at blockcypher.com (Bitcoin + others)
BLOCKCYPHER_API_KEY=YOUR_BLOCKCYPHER_KEY

# Free at tronscan.org (USDT/TRON)
TRONGRID_API_KEY=YOUR_TRONGRID_API_KEY

# ── India-specific APIs ──────────────────────────────────
# MCA21 company lookup (no key required for basic public data)
MCA_BASE_URL=https://www.mca.gov.in/mcafoportal

# ── Graph settings ────────────────────────────────────────
MAX_HOP_DEPTH=5               # max graph expansion depth
MAX_NODES_PER_TRACE=200       # safety cap per investigation
